# Copy to .env and adjust for your environment
# docker = full stack (Postgres+Qdrant+Neo4j) | lite = no Docker | auto
APP_MODE=docker
APP_ENV=development
EMBEDDING_DIM=1024

POSTGRES_HOST=localhost
QDRANT_HOST=localhost
NEO4J_URI=bolt://localhost:7687
REDIS_URL=redis://localhost:6379/0
POSTGRES_PASSWORD=local_dev_secret
NEO4J_PASSWORD=neo4j_local_secret

# Optional GPU stack (docker compose --profile gpu)
VLLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
TEI_URL=http://tei_oss:80
VLLM_URL=http://vllm_oss:8000/v1

# Local dev without Docker TEI/vLLM
EMBEDDING_FALLBACK=sentence-transformers
VLLM_URL=http://localhost:8001/v1

# API
API_SECRET_KEY=change-me-in-production
RATE_LIMIT_PER_MINUTE=60
