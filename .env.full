# Full stack — Postgres + Qdrant + Neo4j + Redis (requires Docker Desktop)
APP_MODE=docker
APP_ENV=development
EMBEDDING_DIM=1024

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=veda_master
POSTGRES_USER=veda
POSTGRES_PASSWORD=local_dev_secret

QDRANT_HOST=localhost
QDRANT_PORT=6333

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_local_secret

REDIS_URL=redis://localhost:6379/0

TEI_URL=http://localhost:8080
VLLM_URL=http://localhost:8001/v1
VLLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct
EMBEDDING_FALLBACK=sentence-transformers
